{
    "name": "psc-acme/toolkit-billing",
    "description": "Package toolkit-billing for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ToolkitBilling\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "illuminate/database": "^11.0",
        "symfony/console": "^7.0",
        "symfony/event-dispatcher": "^7.0",
        "brick/date-time": "^0.7.1",
        "guzzlehttp/guzzle": "^7.0",
        "monolog/monolog": "^3.2.0"
    },
    "require-dev": {
        "behat/behat": "^3.14",
        "phpstan/phpstan-symfony": "^1.0"
    },
    "minimum-stability": "dev",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}